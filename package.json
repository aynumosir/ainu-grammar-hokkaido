	"type": "module",
	"scripts": {
		"dev": "bun scripts/gen-apparatus.ts && bun scripts/gen-grammar-search.ts && vite dev",
		"build": "bun scripts/gen-apparatus.ts && bun scripts/audit-chapters.ts --quiet && bun scripts/gen-grammar-search.ts && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"audit": "bun scripts/audit-chapters.ts",
		"attest:gen": "bun scripts/gen-attestation.ts",
		"attest": "bun scripts/audit-attestation.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.4",
		"@fontsource/ibm-plex-mono": "^5.2.7",
